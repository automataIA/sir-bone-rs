# Uncomment ONE provider below and paste your key. Leave the others commented.
#
# ── Provider: Anthropic-like API ───────────────────────────────
# Set this to use the Anthropic path (also works with z.ai/GLM proxies).
# ANTHROPIC_AUTH_TOKEN=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # optional, default

# ── Provider: OpenAI-like API (also Ollama, Groq, etc.) ────────
# Used when ANTHROPIC_AUTH_TOKEN is not set.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1      # optional, default

# ── Agent settings ─────────────────────────────────────────────
# SIRBONE_MODEL=claude-opus-4-7                   # model name
# SIRBONE_THINKING_BUDGET=10000                   # extended-thinking tokens (Anthropic path; also live-toggled in TUI Settings)
# SIRBONE_NO_LOCALIZE=1                            # disable the localization pre-pass (one-shot + TUI)
# SIRBONE_NO_SNAPSHOT=1                             # disable the per-run workspace snapshot (shadow git; /rollback)
# SIRBONE_CONTEXT_WINDOW=131072                    # context window override (tokens). Normally auto-detected
#                                                  # (Anthropic /v1/models, Groq/OpenRouter /models); set it for
#                                                  # providers that don't expose it (Ollama, bare proxies)

# ── Web search backend (web_search tool) ───────────────────────
# Without this, web_search uses keyless DuckDuckGo. Point it at a
# self-hosted SearXNG/Websurfx JSON endpoint for no rate limit.
# SIRBONE_SEARXNG_URL=http://localhost:8080

# ── Architect tool (optional second-opinion model) ─────────────
# A stronger reviewer the agent can consult on hard decisions. Can be a
# DIFFERENT provider than the executor (e.g. cheap executor + real Opus advisor).
# OPT-IN, default OFF: needs the key AND SIRBONE_ARCHITECT_ENABLE=1. A 2x2 ablation
# on SWE-bench-verified-mini found it net-negative (rewrote correct fixes into
# failing ones), so it no longer activates on key presence alone.
# SIRBONE_ARCHITECT_ENABLE=1                              # required to turn the architect on
# SIRBONE_ARCHITECT_API_KEY=sk-ant-...
# SIRBONE_ARCHITECT_BASE_URL=https://api.anthropic.com   # default
# SIRBONE_ARCHITECT_MODEL=claude-opus-4-8                # default
# SIRBONE_ARCHITECT_MAX_CALLS=3                          # per-task consult cap
# SIRBONE_ARCHITECT_PROVIDER=openai                      # anthropic|openai; default = guess from base url
#
# Example — GLM architect on the z.ai coding plan (OpenAI-compatible endpoint):
#   SIRBONE_ARCHITECT_API_KEY=<your z.ai key>
#   SIRBONE_ARCHITECT_BASE_URL=https://api.z.ai/api/coding/paas/v4
#   SIRBONE_ARCHITECT_MODEL=glm-5.2
#   SIRBONE_ARCHITECT_PROVIDER=openai
